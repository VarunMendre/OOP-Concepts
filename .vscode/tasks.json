{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile and run",
      "type": "shell",
      "command": "bash",
      "args": [
        "-c",
        "g++ -std=c++17 \"${file}\" -o \"${fileBasenameNoExtension}\" && ./${fileBasenameNoExtension} < .vscode/input.txt > .vscode/output.txt"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
